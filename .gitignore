# Claude Code agent state - may contain credentials
# Note: CLAUDE.md (symlink to AGENTS.md) and .claude/commands/ are intentionally committed
.claude/*
!.claude/commands/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Generated report output (personal data)
*.html

# Local squad runtime state
.squad/decisions/
.squad/sessions/
.squad/identity/
.squad/agents/*/history.md
.squad/agents/*/PHASE*_COMPLETE.md
.squad/agents/*/phase*-summary.txt
.squad/phase-status.md
.squad/IMPLEMENTATION-COMPLETE.md
.squad/routing.md
.squad/ceremonies.md
.squad/decisions.md

# macOS
.DS_Store
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
